# Tether Environment Variables
# Copy to .env and fill in your values, or run:
#   bash scripts/generate-secrets.sh
# to generate a .env with cryptographically random secrets.
#
# DO NOT commit .env to version control.

# ---------------------------------------------------------------------------
# PostgreSQL
# ---------------------------------------------------------------------------
POSTGRES_USER=tether
POSTGRES_PASSWORD=changeme
POSTGRES_DB=tether
# Must match POSTGRES_USER, POSTGRES_PASSWORD, and POSTGRES_DB above.
# When running via Docker Compose, host is "postgres" (service name).
DATABASE_URL=postgresql://tether:changeme@postgres:5432/tether

# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------
REDIS_PASSWORD=changeme
# When running via Docker Compose, host is "redis" (service name).
REDIS_URL=redis://:changeme@redis:6379

# ---------------------------------------------------------------------------
# JWT — generate with: openssl rand -hex 32
# ---------------------------------------------------------------------------
JWT_SECRET=changeme
JWT_REFRESH_SECRET=changeme

# ---------------------------------------------------------------------------
# Cookie signing — generate with: openssl rand -hex 32
# ---------------------------------------------------------------------------
COOKIE_SECRET=changeme

# ---------------------------------------------------------------------------
# Coturn TURN server
# COTURN_SECRET must match static-auth-secret in coturn/turnserver.conf.
# Generate with: openssl rand -hex 32
# ---------------------------------------------------------------------------
COTURN_SECRET=changeme
COTURN_REALM=tether.local
# Hostname of the Coturn server (default: localhost for dev; set to public IP/domain in production)
COTURN_HOST=localhost

# ---------------------------------------------------------------------------
# MinIO (S3-compatible object storage)
# ---------------------------------------------------------------------------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=changeme

# ---------------------------------------------------------------------------
# App
# ---------------------------------------------------------------------------
# URL of the frontend client (used for CORS and redirect validation).
# When using docker compose, this is the proxy URL (port 80).
CLIENT_URL=http://localhost
PORT=3001
